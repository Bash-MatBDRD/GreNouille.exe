{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "NODE_ENV": "production"
  },
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**", "server/**", "data/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.ts" }
  ]
}
